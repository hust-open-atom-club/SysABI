{
  "build_info_path": "artifacts/targets/tgoskits_starryos/build-info.json",
  "default_mode": "shell-qemu",
  "revision": "eab9e0a80ffc2ff7e3b5e3207a8659965a27c36a",
  "repo_dir": "",
  "repo_dir_env": "SYZABI_TGOSKITS_DIR",
  "feature_flag_env": "SYZABI_ENABLE_TGOSKITS",
  "supported_arches": [
    "riscv64"
  ],
  "toolchain_probes": [
    "make",
    "debugfs",
    "qemu-system-riscv64",
    "riscv64-linux-musl-gcc"
  ],
  "workspace_subdir": ".",
  "disk_image_path": "target/riscv64gc-unknown-none-elf/rootfs-riscv64.img",
  "guest_binary_path": "/bin/testcase.candidate.bin",
  "shell_prompt": "starry:~#",
  "serial_transport": "stdio",
  "trace_marker_prefix": "__SYZABI_TRACE_EVENT__ ",
  "prepare_timeout_sec": 1800,
  "boot_timeout_sec": 60,
  "command_timeout_sec": 30,
  "prepare_commands": [
    [
      "cargo",
      "xtask",
      "starry",
      "rootfs",
      "--arch",
      "{arch}"
    ]
  ],
  "shell_launch_command": [
    "cargo",
    "xtask",
    "starry",
    "qemu",
    "--arch",
    "{arch}"
  ],
  "healthcheck_shell_command": "pwd && echo __SYZABI_HEALTHCHECK_OK__"
}
