{
  "schema_version": 1,
  "reference": {
    "kind": "local",
    "role": "reference",
    "snapshot_id": "local-linux-reference-tgoskits-starryos",
    "work_root": "artifacts/sandboxes/tgoskits_starryos/reference",
    "kernel_build_command": "uname -r"
  },
  "candidate": {
