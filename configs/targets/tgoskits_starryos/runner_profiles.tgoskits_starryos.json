{
  "schema_version": 1,
  "reference": {
    "kind": "command",
    "command": [
      "python3",
      "{repo_root}/targets/entrypoint.py",
      "--workflow",
      "qemu_linux_riscv64",
      "--mode",
      "system",
      "--binary",
      "{binary_path}",
      "--work-dir",
      "{sandbox_root}"
    ],
    "role": "reference",
    "snapshot_id": "qemu-linux-riscv64-reference",
    "work_root": "artifacts/sandboxes/qemu_linux/riscv64/reference",
    "kernel_build_command": "printf qemu-linux-riscv64",
    "timeout_sec": 120
  },
  "candidate": {
    "binary_name": "testcase.candidate.bin",
    "command_batching_mode": "packaged_per_case",
    "command": [
      "python3",
      "{repo_root}/targets/entrypoint.py",
      "--mode",
      "shell-qemu",
      "--binary",
      "{binary_path}",
      "--work-dir",
      "{sandbox_root}"
    ],
    "kernel_build_command": "printf tgoskits-starryos",
    "kind": "command",
    "role": "candidate",
    "snapshot_id": "tgoskits-starryos-host-direct",
    "timeout_sec": 300,
    "work_root": "artifacts/sandboxes/tgoskits_starryos/candidate"
  }
}
