{
  "allowlist": {
    "deny_name_contains": [
      "$inet",
      "$packet",
      "$netlink",
      "$bluetooth",
      "$usb",
      "$nfc"
    ],
    "deny_prefixes": [
      "epoll",
      "poll",
      "select",
      "io_uring",
      "mount",
      "umount",
      "pivot_root",
      "setns",
      "unshare",
      "bpf",
      "perf_event",
      "signalfd",
      "inotify",
      "fanotify",
      "kcmp",
      "keyctl",
      "request_key",
      "add_key",
      "capset",
      "capget",
      "quotactl",
      "ptrace",
      "process_vm",
      "swapon",
      "swapoff",
      "reboot"
    ],
    "pseudo_prefix": "syz_",
    "syscalls": [
      "open",
      "openat",
      "read",
      "write",
      "pread64",
      "pwrite64",
      "lseek",
      "close",
      "fstat",
      "newfstatat",
      "mkdir",
      "unlink",
      "rename",
      "mmap",
      "munmap",
      "mprotect",
      "brk",
      "getpid",
      "getppid",
      "clone",
      "wait4",
      "exit",
      "exit_group",
      "pipe",
      "pipe2",
      "eventfd",
      "eventfd2",
      "socketpair"
    ],
    "threading_sensitive_prefixes": [
      "futex",
      "sched_",
      "epoll",
      "poll",
      "select",
      "rt_sig",
      "timerfd",
      "signalfd"
    ]
  },
  "arch": "amd64",
  "build": {
    "cflags": []
  },
  "capabilities": {
    "supports_batch_execution": false,
    "supports_preflight": false,
    "supports_snapshot_reuse": false
  },
  "classification": {
    "baseline_invalid": "BASELINE_INVALID",
    "bug_likely": "BUG_LIKELY",
    "no_diff": "NO_DIFF",
    "unsupported_feature": "UNSUPPORTED_FEATURE",
    "weak_spec_or_env_noise": "WEAK_SPEC_OR_ENV_NOISE"
  },
  "normalization": {
    "drop_comment_prefixes": [
      "#",
      "//"
    ],
    "max_probe_bytes": 4096,
    "preview_bytes": 32,
    "runtime_syscalls": [
      "mmap",
      "munmap",
      "brk"
    ]
  },
  "paths": {
    "artifacts_dir": "artifacts/runs",
    "build_dir": "build/testcases",
    "corpus_meta": "corpus/meta",
    "corpus_normalized": "corpus/normalized",
    "corpus_raw": "corpus/raw",
    "corpus_rejected": "corpus/rejected",
    "eligible_file": "eligible_programs/baseline.jsonl",
    "go_archive_dir": "artifacts/toolchains/go",
    "go_root": "artifacts/toolchains/go/current/go",
    "reports_dir": "reports/baseline",
    "syzkaller_dir": "third_party/syzkaller",
    "temp_dir": "artifacts/tmp"
  },
  "runner_profiles_path": "configs/runner_profiles.json",
  "schema_version": 1,
  "stability": {
    "baseline_invalid_threshold": 0.1,
    "rerun_count": 2,
    "timeout_sec": 10
  },
  "syzkaller": {
    "commit": "5b92003d577daa0766edda7ed533d75e1ac545ff",
    "go_platform": "linux-amd64",
    "go_version": "1.26.0",
    "repo": "https://github.com/google/syzkaller.git"
  },
  "target": "linux",
  "target_os": "linux",
  "thresholds": {
    "signoff": {
      "baseline_invalid_rate": 0.1,
      "build_success_rate": 0.9,
      "dual_execution_completion_rate": 0.85,
      "eligible_program_count_min": 1000,
      "import_success_rate": 0.95,
      "require_minimized_report": true,
      "trace_success_rate": 0.95
    },
    "smoke": {
      "baseline_invalid_rate": 0.2,
      "canonical_success_rate": 1.0,
      "trace_success_rate": 0.9
    }
  },
  "workflow": "baseline"
}
