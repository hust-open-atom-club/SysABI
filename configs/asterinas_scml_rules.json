{
  "workflow": "asterinas_scml",
  "target": "asterinas",
  "schema_version": 1,
  "target_os": "linux",
  "arch": "amd64",
  "runner_profiles_path": "configs/runner_profiles.asterinas_scml.json",
  "compat_manifest_path": "compat_specs/asterinas/scml-manifest.json",
  "generation_profile_path": "compat_specs/asterinas/generation-profile.json",
  "asterinas": {
    "repo_dir": "third_party/asterinas",
    "revision": "main",
    "docker_image": "asterinas/asterinas:0.17.1-20260317",
    "docker_repo_dir": "/root/asterinas",
    "docker_workspace_dir": "/workspace",
    "docker_workdir": "/root/asterinas",
    "build_timeout_sec": 3600,
    "run_timeout_sec": 600,
    "base_initramfs_path": "third_party/asterinas/test/initramfs/build/initramfs.cpio.gz",
    "build_info_path": "artifacts/asterinas/build-info.json"
  },
  "paths": {
    "syzkaller_dir": "third_party/syzkaller",
    "go_root": "artifacts/toolchains/go/current/go",
    "go_archive_dir": "artifacts/toolchains/go",
    "temp_dir": "artifacts/tmp",
    "corpus_raw": "corpus/raw",
    "corpus_normalized": "corpus/normalized",
    "corpus_meta": "corpus/meta",
    "corpus_rejected": "corpus/rejected",
    "targets_file": "eligible_programs/asterinas_scml.targets.jsonl",
    "generated_file": "eligible_programs/asterinas_scml.generated.jsonl",
    "static_eligible_file": "eligible_programs/asterinas_scml.static.jsonl",
    "eligible_file": "eligible_programs/asterinas_scml.jsonl",
    "generated_raw_dir": "artifacts/generated/asterinas_scml/raw",
    "generated_normalized_dir": "artifacts/generated/asterinas_scml/normalized",
    "generated_meta_dir": "artifacts/generated/asterinas_scml/meta",
    "build_dir": "build/asterinas_scml/testcases",
    "artifacts_dir": "artifacts/runs/asterinas_scml",
    "reports_dir": "reports/asterinas_scml",
    "candidate_initramfs_packages_dir": "artifacts/asterinas/initramfs-packages"
  },
  "derivation": {
    "source_eligible_file": "eligible_programs/baseline.jsonl",
    "generated_source_eligible_file": "eligible_programs/asterinas_scml.generated.jsonl",
    "accept_reasons": [
      "scml_manifest_allowed",
      "profile_enabled_category",
      "unspecialized_sequence"
    ],
    "rejection_taxonomy": {
      "specialized_variant": "specialized_variant_not_allowed",
      "sequence_too_short": "sequence_too_short",
      "sequence_too_long": "sequence_too_long",
      "syscall_not_in_manifest": "syscall_not_in_manifest",
      "deferred_category": "deferred_category",
      "manifest_disabled": "manifest_disabled"
    }
  },
  "preflight": {
    "source_eligible_file": "eligible_programs/asterinas_scml.static.jsonl",
    "scml_root": "third_party/asterinas/book/src/kernel/linux-compatibility/syscall-flag-coverage",
    "artifact_dir": "artifacts/preflight/asterinas_scml",
    "timeout_sec": 20,
    "rejection_taxonomy": {
      "syscall_not_in_manifest": "syscall_not_in_manifest",
      "unsupported_flag_pattern": "unsupported_flag_pattern",
      "unsupported_struct_pattern": "unsupported_struct_pattern",
      "unsupported_path_pattern": "unsupported_path_pattern",
      "deferred_category": "deferred_category",
      "scml_parser_gap": "scml_parser_gap",
      "preflight_build_failure": "preflight_build_failure",
      "preflight_runtime_failure": "preflight_runtime_failure",
      "preflight_runtime_timeout": "preflight_runtime_timeout",
      "preflight_matcher_timeout": "preflight_matcher_timeout"
    }
  },
  "normalization": {
    "preview_bytes": 32,
    "max_probe_bytes": 4096,
    "drop_comment_prefixes": [
      "#",
      "//"
    ],
    "runtime_syscalls": [
      "mmap",
      "munmap",
      "brk"
    ]
  },
  "stability": {
    "rerun_count": 2,
    "timeout_sec": 120,
    "baseline_invalid_threshold": 0.1
  },
  "capabilities": {
    "supports_batch_execution": true,
    "supports_preflight": true,
    "supports_snapshot_reuse": false
  },
  "parallel": {
    "jobs": 8,
    "candidate_batch_size": 100
  },
  "build": {
    "cflags": [
      "-static"
    ]
  },
  "classification": {
    "no_diff": "NO_DIFF",
    "baseline_invalid": "BASELINE_INVALID",
    "weak_spec_or_env_noise": "WEAK_SPEC_OR_ENV_NOISE",
    "unsupported_feature": "UNSUPPORTED_FEATURE",
    "bug_likely": "BUG_LIKELY"
  },
  "thresholds": {
    "smoke": {
      "total_min": 100,
      "build_success_rate": 0.98,
      "dual_execution_completion_rate": 0.9,
      "trace_success_rate": 0.98,
      "canonical_success_rate": 1.0,
      "baseline_invalid_rate": 0.05
    },
    "signoff": {
      "total_min": 500,
      "build_success_rate": 0.98,
      "dual_execution_completion_rate": 0.92,
      "trace_success_rate": 0.98,
      "canonical_success_rate": 1.0,
      "baseline_invalid_rate": 0.05,
      "require_minimized_report": true
    }
  }
}
